<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- Custom binding-redirection attributes live in Properties\AssemblyInfo.cs -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType>true</GenerateBindingRedirectsOutputType>

    <!-- VSIX settings -->
    <VSSDKBuildToolsAutoSetup>true</VSSDKBuildToolsAutoSetup>
    <VsixDeployOnDebug>true</VsixDeployOnDebug>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
  </PropertyGroup>

  <ItemGroup>
    <ProjectCapability Include="CreateVsixContainer" />
  </ItemGroup>

  <!-- Auto-generated files (use Update because SDK auto-includes *.cs) -->
  <ItemGroup>
    <Compile Update="source.extension.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>source.extension.vsixmanifest</DependentUpon>
    </Compile>
    <Compile Update="VSCommandTable.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>VSCommandTable.vsct</DependentUpon>
    </Compile>
    <Compile Update="Editor\DocumentOutlineControl.xaml.cs">
      <DependentUpon>DocumentOutlineControl.xaml</DependentUpon>
    </Compile>
    <Compile Update="Editor\FloatingToolbar.xaml.cs">
      <DependentUpon>FloatingToolbar.xaml</DependentUpon>
    </Compile>
  </ItemGroup>

  <!-- XAML pages (UseWPF auto-globs them; Update adds the generator) -->
  <ItemGroup>
    <Page Update="Editor\DocumentOutlineControl.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Editor\FloatingToolbar.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>

  <!-- VSCT command table -->
  <ItemGroup>
    <AvailableItemName Include="VSCTCompile" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="VSCommandTable.vsct" />
    <VSCTCompile Include="VSCommandTable.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
      <Generator>VsctGenerator</Generator>
      <LastGenOutput>VSCommandTable.cs</LastGenOutput>
    </VSCTCompile>
  </ItemGroup>

  <!-- VSIX manifest -->
  <ItemGroup>
    <None Update="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
      <Generator>VsixManifestGenerator</Generator>
      <LastGenOutput>source.extension.cs</LastGenOutput>
    </None>
  </ItemGroup>

  <!-- Resources included in VSIX -->
  <ItemGroup>
    <Content Include="Margin\highlight-dark.css">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\highlight.css">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\mathjax.js">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\color.js">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\md-template.html">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\mermaid.min.js">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\mermaid.min.js.LICENSE.txt" />
    <Content Include="Margin\prism-dark.css">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\prism.css">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Margin\prism.js">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Registry.pkgdef">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Resources\Icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="..\LICENSE">
      <Link>Resources\LICENSE</Link>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>

  <!-- .NET Framework assemblies not covered by NuGet packages -->
  <ItemGroup>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Design" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsBase" />
    <Reference Include="WindowsFormsIntegration" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Community.VisualStudio.VSCT" Version="16.0.29.14" PrivateAssets="all" />
    <PackageReference Include="Community.VisualStudio.Toolkit.17" Version="17.0.551" ExcludeAssets="Runtime">
      <IncludeAssets>compile; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="18.5.40034" PrivateAssets="all" />
    <PackageReference Include="Markdig" Version="1.1.2" IncludeAssets="all" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3485.44" />
  </ItemGroup>

  <!-- Include Markdig transitive dependencies (System.Memory, etc.) in the VSIX container -->
  <Target Name="IncludeMarkdigDependencies" AfterTargets="GetVsixSourceItems">
    <ItemGroup>
      <VSIXSourceItem Include="@(ReferenceCopyLocalPaths)" Condition="'%(ReferenceCopyLocalPaths.NuGetPackageId)' == 'System.Memory'&#xD;&#xA;                                  or '%(ReferenceCopyLocalPaths.NuGetPackageId)' == 'System.Buffers'&#xD;&#xA;                                  or '%(ReferenceCopyLocalPaths.NuGetPackageId)' == 'System.Numerics.Vectors'&#xD;&#xA;                                  or '%(ReferenceCopyLocalPaths.NuGetPackageId)' == 'System.Runtime.CompilerServices.Unsafe'" />
    </ItemGroup>
  </Target>

</Project>
